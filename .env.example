# LogiLake — Variables de entorno
# Copia este archivo como .env y completa los valores
# El .env nunca se sube al repo (está en .gitignore)

# ── Netlify Function — SQL Agent ──────────────────────────────────────────────
# API key de OpenAI para el SQL Agent (GPT-4o)
# Configurar en Netlify: Site settings → Environment variables
OPENAI_API_KEY=sk-...

# ── Opcional: Kafka ───────────────────────────────────────────────────────────
# Solo necesario si usas el modo streaming con Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=olist_orders
